    <script>
        // 检查是否需要显示开机页面
        window.onload = function() {
            const firstVisitTime = localStorage.getItem('firstVisitTime');
            const currentTime = new Date().getTime();

            if (!firstVisitTime) {
                // 如果没有记录首次访问时间，则记录当前时间
                localStorage.setItem('firstVisitTime', currentTime);
                showBootScreen(); // 显示开机页面
            } else {
                const timeDifference = (currentTime - firstVisitTime) / (1000 * 60); // 时间差（分钟）
                if (timeDifference = 30) {
                    // 如果时间差在30分钟内，则显示开机页面
                    showBootScreen();
                } else {
                    // 如果时间差超过30分钟，则直接进入主页面
                    document.getElementById('mainScreen').style.display = 'flex';
                }
            }
        };

        // 显示开机页面
        function showBootScreen() {
            document.getElementById('bootScreen').style.display = 'flex';
            document.getElementById('mainScreen').style.display = 'none';

            // 显示第一行文字和底部文字
            document.getElementById('bootText1').style.display = 'block';
            document.getElementById('bootBottomText').style.display = 'block';

            // 2秒后隐藏第一行文字和底部文字
            setTimeout(() => {
                document.getElementById('bootText1').style.display = 'none';
                document.getElementById('bootBottomText').style.display = 'none';

                // 显示第二行文字
                document.getElementById('bootText2').style.display = 'block';

                // 2秒后跳转到主页面
                setTimeout(() => {
                    document.getElementById('bootScreen').style.display = 'none';
                    document.getElementById('mainScreen').style.display = 'flex';
                }, 2000);
            }, 2000);
        }
    </script>
